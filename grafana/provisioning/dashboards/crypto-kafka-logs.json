{
  "title": "Crypto Kafka Logs",
  "uid": "crypto-kafka-logs",
  "tags": ["kafka", "crypto"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "All Service Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=~\"kafka-.+\"}",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Producer",
      "type": "logs",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=\"kafka-producer\"}",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Consumer BTC",
      "type": "logs",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=\"kafka-consumer-btc\"}",
          "queryType": "range",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Consumer LTC",
      "type": "logs",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=\"kafka-consumer-ltc\"}",
          "queryType": "range",
          "refId": "A"
        }
      ]
    }
  ]
}
